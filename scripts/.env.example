# Copy to .env and fill in your values — NEVER commit .env to git

# ── Deployer wallet ──────────────────────────────────────────────────────────
# Bitcoin testnet WIF private key (starts with 'c' for OPNet testnet)
DEPLOYER_WIF=

# ML-DSA quantum-resistant private key (hex-encoded)
# Generate: opnet keygen mldsa
DEPLOYER_MLDSA=

# ── Deployed contract addresses (fill in after running deploy.ts) ────────────
VAULT_ADDRESS=
MOCK_MOTO_ADDRESS=
