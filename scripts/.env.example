# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your wallet WIF private key (from Unisat or another BTC wallet)
DEPLOYER_WIF=

# Your MLDSA private key (hex-encoded, for quantum-resistant signing)
# Generate with: opnet keygen mldsa
DEPLOYER_MLDSA_PRIV=

# Network: testnet or mainnet
NETWORK=testnet
