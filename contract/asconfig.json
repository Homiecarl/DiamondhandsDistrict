{
  "targets": {
    "debug": {
      "outFile": "build/ProofOfHodl.wasm",
      "textFile": "build/ProofOfHodl.wat",
      "sourceMap": true,
      "debug": true
    },
    "release": {
      "outFile": "build/ProofOfHodl.wasm",
      "textFile": "build/ProofOfHodl.wat",
      "optimize": true,
      "optimizeLevel": 3,
      "shrinkLevel": 1
    }
  },
  "options": {
    "transform": ["@btc-vision/opnet-transform"],
    "runtime": "stub",
    "exportRuntime": false,
    "enable": ["simd"],
    "initialMemory": 100,
    "maximumMemory": 16384,
    "use": ["abort=~lib/builtins/abort"]
  }
}
